{
  "name": "webgpu-ascii-renderer",
  "version": "1.0.0",
  "description": "WebGPU-powered 3D ASCII renderer for the web",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:types": "tsc --emitDeclarationOnly",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webgpu",
    "ascii",
    "3d",
    "renderer",
    "graphics",
    "gltf"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@types/node": "^25.3.2",
    "@webgpu/types": "^0.1.69",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
